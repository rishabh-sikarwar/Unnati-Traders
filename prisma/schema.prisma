generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id        String       @id @default(uuid())
  name      String
  code      String       @unique @default("UT")
  type      LocationType
  address   String?
  createdAt DateTime     @default(now())

  users       User[]
  inventories Inventory[]
  stockSnapshots StockSnapshot[]
  invoices    Invoice[]
  purchases   Purchase[]
  returns     ReturnLog[]
  transferFromLogs TransferLog[] @relation("TransferFromLocation")
  transferToLogs   TransferLog[] @relation("TransferToLocation")
}

model User {
  id        String   @id
  email     String?  @unique
  role      UserRole @default(VISITOR)
  fullName  String?
  mobile    String?
  createdAt DateTime @default(now())

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  invoices  Invoice[]
  purchases Purchase[]
  returns   ReturnLog[]
  transferLogs TransferLog[]
}

model Product {
  id        String @id @default(uuid())
  sku       String @unique
  brand     String @default("Apollo")
  modelName String
  size      String

  category TyreCategory @default(GENERAL)
  tubeType String       @default("T/L")
  hsnCode  String?      @default("4011")

  description String?
  basePrice   Decimal  @db.Decimal(18, 2)
  gstRate     Int      @default(28)
  lowStock    Int      @default(5)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  inventories   Inventory[]
  stockSnapshots StockSnapshot[]
  invoiceItems  InvoiceItem[]
  purchaseItems PurchaseItem[]
  returns       ReturnLog[]
  transferLogs  TransferLog[]
}

model Inventory {
  id          String   @id @default(uuid())
  quantity    Int      @default(0)
  lastUpdated DateTime @default(now()) @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

model Customer {
  id         String       @id @default(uuid())
  type       CustomerType
  name       String
  phone      String?
  gstNumber  String?
  address    String?
  openingBalance Decimal   @default(0) @db.Decimal(18, 2)
  isArchived Boolean      @default(false)
  createdAt  DateTime     @default(now())

  invoices Invoice[]
  payments PaymentLog[]
  returns  ReturnLog[]
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  subtotal      Decimal   @db.Decimal(18, 2)
  totalGst      Decimal   @db.Decimal(18, 2)
  grandTotal    Decimal   @db.Decimal(18, 2)
  status        InvoiceStatus @default(COMPLETED)
  createdAt     DateTime      @default(now())

  paymentMode PaymentMode @default(CASH)
  amountPaid  Decimal     @default(0) @db.Decimal(18, 2)
  splitCash   Decimal     @default(0) @db.Decimal(18, 2)
  splitUpi    Decimal     @default(0) @db.Decimal(18, 2)
  splitCard   Decimal     @default(0) @db.Decimal(18, 2)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  items InvoiceItem[]
  payments PaymentLog[]
}

model InvoiceItem {
  id         String @id @default(uuid())
  quantity   Int
  unitPrice  Decimal  @db.Decimal(18, 2)
  totalPrice Decimal  @db.Decimal(18, 2)
  tyreCode   String?

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PaymentLog {
  id          String      @id @default(uuid())
  amount      Decimal   @db.Decimal(18, 2)
  paymentMode PaymentMode
  remarks     String?
  createdAt   DateTime    @default(now())
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  userId      String?
  invoiceId   String?
  invoice     Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Purchase {
  id            String         @id @default(uuid())
  invoiceNumber String // The official Apollo Invoice Number
  supplierName  String         @default("Apollo Tyres")
  totalAmount   Decimal  @db.Decimal(18, 2)
  status        PurchaseStatus @default(COMPLETED)
  createdAt     DateTime       @default(now())
  purchaseDate  DateTime       @default(now())

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  items PurchaseItem[]
}

model PurchaseItem {
  id        String @id @default(uuid())
  quantity  Int
  unitCost  Decimal  @db.Decimal(18, 2) // Buying price (Cost), not selling price
  totalCost Decimal   @db.Decimal(18, 2)

  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ReturnLog {
  id           String          @id @default(uuid())
  quantity     Int
  refundAmount Decimal        @db.Decimal(18, 2)
  condition    ReturnCondition @default(GOOD)
  reason       String?
  createdAt    DateTime        @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

model TransferLog {
  id             String   @id @default(uuid())
  quantity       Int
  createdAt      DateTime @default(now())

  productId      String
  product        Product  @relation(fields: [productId], references: [id])

  fromLocationId String
  fromLocation   Location @relation("TransferFromLocation", fields: [fromLocationId], references: [id])

  toLocationId   String
  toLocation     Location @relation("TransferToLocation", fields: [toLocationId], references: [id])

  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
}

model StockSnapshot {
  id         String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity    Int
  month       Int
  year        Int
  createdAt   DateTime @default(now())

  @@unique([productId, locationId, month, year])
}

enum PurchaseStatus {
  COMPLETED
  PENDING
}

enum UserRole {
  ADMIN
  SHOPKEEPER
  DEALER
  VISITOR
}

enum LocationType {
  WAREHOUSE
  RETAIL_SHOP
}

enum CustomerType {
  DISTRIBUTOR
  SUB_DEALER
  RETAIL
}

enum InvoiceStatus {
  COMPLETED
  PENDING
}

enum TyreCategory {
  TRUCK_BUS_BIAS
  TRUCK_BUS_RADIAL
  TRACTOR_FARM
  TRACTOR_FRONT
  LIGHT_COMMERCIAL
  PICKUP_BIAS
  PICKUP_RADIAL
  LCV_RADIAL
  SMALL_COMMERCIAL
  TRACTOR_TRAILER
  TWO_WHEELER
  THREE_WHEELER
  TUBE
  INDUSTRIAL
  JEEP
  SCV_RADIAL
  PASSENGER_CAR
  PREMIUM_CAR
  GENERAL
}

enum PaymentMode {
  CASH
  UPI
  CARD
  CREDIT
  MULTIPLE
  RETURN_CREDIT
}

enum ReturnCondition {
  GOOD
  DEFECTIVE
}
